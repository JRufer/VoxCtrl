{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "VoxCtrl",
  "version": "0.1.9",
  "identifier": "ai.voxctrl.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: asset: https://asset.localhost; connect-src ipc: http://ipc.localhost"
    },
    "windows": [
      {
        "label": "settings",
        "title": "VoxCtrl Settings",
        "width": 700,
        "height": 850,
        "minWidth": 700,
        "minHeight": 500,
        "visible": false,
        "resizable": true,
        "decorations": true,
        "url": "/settings"
      },
      {
        "label": "overlay",
        "title": "VoxCtrl Overlay",
        "width": 560,
        "height": 160,
        "visible": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "url": "/overlay"
      },
      {
        "label": "history",
        "title": "VoxCtrl — Transcript History",
        "width": 600,
        "height": 500,
        "visible": false,
        "url": "/history"
      },
      {
        "label": "udev-warning",
        "title": "VoxCtrl Diagnostics",
        "width": 460,
        "height": 380,
        "visible": false,
        "alwaysOnTop": true,
        "resizable": false,
        "url": "/udev-warning"
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "resources/cudart64_12.dll",
      "resources/cublas64_12.dll",
      "resources/cublasLt64_12.dll"
    ],
    "externalBin": [],
    "linux": {
      "deb": {
        "depends": [
          "libwebkit2gtk-4.1-0",
          "libssl3",
          "libayatana-appindicator3-1",
          "wtype | xdotool",
          "wl-clipboard | xclip"
        ]
      }
    },
    "windows": {
      "webviewInstallMode": {
        "type": "embedBootstrapper"
      }
    }
  }
}